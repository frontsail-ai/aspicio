{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    /*
     * The dts build must resolve @aspicio/core through its built package
     * exports, not the source mapping — with paths, tsgo emits stray .d.ts
     * files next to core's sources. Requires core to be built first, which
     * `vp run -r build` guarantees via the workspace dependency order.
     */
    "paths": {}
  }
}
