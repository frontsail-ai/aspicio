{
  "compilerOptions": {
    "target": "esnext",
    "lib": ["es2023", "dom", "dom.iterable"],
    "moduleDetection": "force",
    "module": "preserve",
    "moduleResolution": "bundler",
    "allowJs": true,
    "checkJs": false,
    "strict": true,
    "noUnusedLocals": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "paths": {
      "@aspicio/core": ["../core/src/index.ts"],
      "@aspicio/elements": ["../elements/src/index.ts"]
    },
    "verbatimModuleSyntax": true,
    "skipLibCheck": true
  },
  "exclude": ["dist", "node_modules"]
}
