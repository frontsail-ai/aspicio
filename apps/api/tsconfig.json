{
  "compilerOptions": {
    "target": "es2023",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["ES2023", "WebWorker"],
    "types": ["@cloudflare/workers-types"],
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "strict": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@aspicio/core": ["../../packages/core/src/index.ts"],
      "@aspicio/widget/meta": ["../widget/src/meta.ts"]
    },
    "resolveJsonModule": true
  },
  "include": ["src/**/*.ts", "../widget/src/meta.ts"]
}
